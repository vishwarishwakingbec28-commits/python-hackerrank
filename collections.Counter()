from collections import Counter

X = int(input())
shoe_inventory = Counter(map(int, input().split()))
N = int(input())
total_earnings = 0

for _ in range(N):
    size, price = map(int, input().split())
    
    if shoe_inventory[size] > 0:
        total_earnings += price
        shoe_inventory[size] -= 1

print(total_earnings)
