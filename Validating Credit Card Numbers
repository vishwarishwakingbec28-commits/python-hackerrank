import re
for _ in range(int(input())):
    s = input()
    structure_match = bool(re.match(r"^[456](?:\d{15}|\d{3}(?:-\d{4}){3})$", s))
    
    if structure_match:
        clean_s = s.replace("-", "")
        if not re.search(r"(\d)\1{3}", clean_s):
            print("Valid")
        else:
            print("Invalid")
    else:
        print("Invalid")
