from collections import deque

def solve():
    try:
        t = int(input())
for _ in range(t):
    n = int(input())
    cubes = deque(map(int, input().split()))
    last_placed = float('inf')
    possible = True
            
 while cubes:
    if cubes[0] >= cubes[-1]:
        current = cubes.popleft()
    else:
        current = cubes.pop()
                
    if current <= last_placed:
        last_placed = current
    else:
        possible = False
        break
      
     print("Yes" if possible else "No")
     except EOFError:
    pass

     if __name__ == "__main__":
     solve()
