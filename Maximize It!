from itertools import product

def solve():
    k, m = map(int, input().split())
    
    lists = []
    for _ in range(k):
        row = list(map(int, input().split()))[1:]
        lists.append(row)
    max_s = 0
    for combination in product(*lists):
        current_sum = sum(x**2 for x in combination) % m
        if current_sum > max_s:
            max_s = current_sum
            
    print(max_s)

if __name__ == "__main__":
    solve()
