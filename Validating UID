import sys
def check_uid(uid):
    if len(uid) != 10:
        return False
    
    if not uid.isalnum():
        return False
    
    if len(set(uid)) != 10:
        return False
    
    upper_count = sum(1 for char in uid if char.isupper())
    if upper_count < 2:
        return False
    
    digit_count = sum(1 for char in uid if char.isdigit())
    if digit_count < 3:
        return False
    
    return True

if __name__ == '__main__':
    try:
        t_str = sys.stdin.readline().strip()
        if t_str:
            t = int(t_str)
            for _ in range(t):
                uid = sys.stdin.readline().strip()
                if check_uid(uid):
                    print("Valid")
                else:
                    print("Invalid")
    except EOFError:
        pass
